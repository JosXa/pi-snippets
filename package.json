{
  "name": "pi-snippets",
  "version": "1.0.0",
  "description": "Hashtag-based snippet expansion for Pi",
  "keywords": ["pi-package", "pi-coding-agent", "snippets"],
  "type": "module",
  "pi": {
    "extensions": ["./index.ts"],
    "skills": ["./skills"]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@sinclair/typebox": "*"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "@types/bun": "latest",
    "@types/node": "^22.0.0"
  },
  "scripts": {
    "format:check": "biome check .",
    "format:fix": "biome check --write .",
    "test": "bun test tests/expander.test.ts tests/loader.test.ts tests/arg-parser.test.ts tests/skill-renderer.test.ts",
    "test:e2e": "bun test tests/e2e.test.ts"
  }
}
